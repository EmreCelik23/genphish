# =================================
# tracker-service environment template
# Copy this file to `.env` and set real values per environment.
# =================================

# --- Server ---
PORT=8081
GIN_MODE=release
PUBLISH_TIMEOUT_MS=300

# --- Kafka ---
KAFKA_BROKERS=kafka-1:9092,kafka-2:9092
KAFKA_TOPIC=tracking_events
KAFKA_CLIENT_ID=tracker-service
KAFKA_WRITE_TIMEOUT_MS=750
KAFKA_BATCH_TIMEOUT_MS=5
KAFKA_BATCH_SIZE=200
KAFKA_ASYNC=true

# --- Redirect targets ---
# You can use {campaignId} placeholder for Next.js dynamic routes:
#   https://app.example.com/phishing/{campaignId}
# Incoming `lang` query is automatically normalized (TR/EN) and forwarded on redirects.
# If `lang` is omitted or unknown, default is TR.
LANDING_PAGE_URL=https://security-awareness.example.com/phishing/{campaignId}
AWARENESS_PAGE_URL=https://security-awareness.example.com/awareness
