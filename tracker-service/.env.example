PORT=8081
GIN_MODE=release

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=tracking_events
KAFKA_CLIENT_ID=tracker-service
KAFKA_WRITE_TIMEOUT_MS=750
KAFKA_BATCH_TIMEOUT_MS=5
KAFKA_BATCH_SIZE=200
KAFKA_ASYNC=true

LANDING_PAGE_URL=http://localhost:3000/phishing
AWARENESS_PAGE_URL=http://localhost:3000/awareness

# Security
REQUIRE_SIGNED_LINKS=true
TRACKING_SIGNATURE_SECRET=CHANGE_ME_TRACKING_SIGNATURE_SECRET
OAUTH_STATE_HMAC_SECRET=CHANGE_ME_OAUTH_STATE_SECRET
OAUTH_STATE_TTL_SECONDS=600
NONCE_STORE_PROVIDER=memory

# Redis nonce store (recommended in production multi-instance deployments)
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
