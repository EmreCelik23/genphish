# =================================
# ai-engine-service environment template
# KULLANIM: Bu dosyayı kopyalayıp `.env` adında yeni bir dosya oluşturun
# ve CHANGE_ME yazan yerlere gerçek değerlerinizi girin.
# DİKKAT: Gerçek `.env` dosyanızı ASLA Git'e (commit) dahil etmeyin!
# =================================

# --- App ---
APP_NAME=ai-engine-service
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=5000

# --- Security ---
SERVICE_AUTH_ENABLED=true
SERVICE_AUTH_TOKEN=CHANGE_ME_INTERNAL_SERVICE_TOKEN
SERVICE_TOKEN_HEADER=X-Service-Token
COMPANY_HEADER=X-Company-Id
FAIL_ON_UNSAFE_DEFAULTS=true

# --- AI Provider ---
# Kullanılabilir sağlayıcılar: "stub" (test için), "openai", "anthropic", "gemini".
AI_PROVIDER=stub

# OpenAI (Seçiliyse doldurun)
OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4

# Anthropic / Claude (Seçiliyse doldurun)
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TEMPERATURE=0.4

# Google Gemini (Seçiliyse doldurun)
GOOGLE_API_KEY=CHANGE_ME_GOOGLE_KEY
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.4

# --- MongoDB ---
MONGODB_URI=mongodb://genphish_root:CHANGE_ME_STRONG_MONGO_PASSWORD@mongodb:27017
MONGODB_DB=genphish_ai
MONGODB_COLLECTION_TEMPLATES=templates
MONGODB_COLLECTION_FALLBACK_TEMPLATES=fallback_templates

# --- Kafka ---
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=ai-engine-service-group
KAFKA_CLIENT_ID=ai-engine-service
KAFKA_AUTO_OFFSET_RESET=earliest
TOPIC_AI_GENERATION_REQUESTS=ai_generation_requests
TOPIC_AI_GENERATION_RESPONSES=ai_generation_responses

# --- Resilience ---
GENERATION_TIMEOUT_SECONDS=30
PROMPT_DIR=app/prompts