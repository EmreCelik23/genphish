# ==========================================
# GenPhish root environment template
# Used by docker-compose.yml at repository root
# ==========================================
#
# Usage:
#   cp .env.example .env
#   docker compose up -d
#
# Notes:
# - Never commit your real `.env`.
# - Use long, random passwords in real environments.

# PostgreSQL
POSTGRES_USER=genphish_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=genphish_db

# MongoDB (root user for local/dev bootstrap)
MONGO_ROOT_USER=genphish_root
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_MONGO_PASSWORD

# API Gateway / App stack
GATEWAY_PORT=8088
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088
TRACKER_BASE_URL_PUBLIC=http://localhost:8088
APP_PUBLIC_BASE_URL=http://localhost:8088
INTERNAL_SERVICE_TOKEN=CHANGE_ME_INTERNAL_SERVICE_TOKEN
