# ================================
# campaign-service environment template
# Copy this file to `.env` and set real values per environment.
# ================================

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genphish_db
POSTGRES_USER=genphish_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- JPA ---
# Recommended for production: validate / none
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9092
KAFKA_CONSUMER_GROUP_ID=campaign-service-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_TRUSTED_PACKAGES=com.genphish.campaign.*

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Internal service URLs ---
TRACKER_BASE_URL=http://tracker-service:8081
PYTHON_SERVICE_BASE_URL=http://ai-engine-service:5000
APP_PUBLIC_BASE_URL=http://localhost:8080
REFERENCE_IMAGE_DIR=./uploads/reference-images
REFERENCE_IMAGE_STORAGE=local
REFERENCE_IMAGE_RETENTION_DAYS=30
REFERENCE_IMAGE_S3_BUCKET=
REFERENCE_IMAGE_S3_KEY_PREFIX=reference-images
REFERENCE_IMAGE_S3_REGION=us-east-1
REFERENCE_IMAGE_S3_ENDPOINT=
REFERENCE_IMAGE_S3_PATH_STYLE=true
REFERENCE_IMAGE_S3_ACCESS_KEY=
REFERENCE_IMAGE_S3_SECRET_KEY=
REFERENCE_IMAGE_S3_PRESIGN_DURATION_SECONDS=1800

# --- App tuning ---
CAMPAIGN_HIGH_RISK_THRESHOLD=70.0
CAMPAIGN_CHECK_RATE_MS=300000
HTTP_LOG_PAYLOADS=false

# --- API / Service Security ---
APP_SECURITY_ENABLED=true
APP_API_TOKEN=CHANGE_ME_STRONG_API_TOKEN
AI_SERVICE_TOKEN=CHANGE_ME_AI_SERVICE_TOKEN
SERVICE_TOKEN_HEADER=X-Service-Token
COMPANY_HEADER=X-Company-Id
REFERENCE_IMAGES_PUBLIC=true
TRACKING_SIGNATURE_SECRET=CHANGE_ME_TRACKING_SIGNATURE_SECRET
TRACKING_LINK_TTL_SECONDS=604800
OAUTH_STATE_HMAC_SECRET=CHANGE_ME_OAUTH_STATE_SECRET
OAUTH_STATE_TTL_SECONDS=600

# --- CORS ---
# Comma-separated list if multiple origins are needed.
CORS_ALLOWED_ORIGINS=https://app.example.com

# --- Observability ---
TRACING_SAMPLING_PROBABILITY=1.0
LOG_LEVEL_GENPHISH=INFO
