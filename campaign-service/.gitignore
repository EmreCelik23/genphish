# Maven build output
/target/

# Compiled artifacts
*.class
*.jar
*.war
*.ear

# Maven release/versioning leftovers
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
flattened-pom.xml

# Local Maven runtime state
.mvn/timing.properties

# Test/coverage runtime files
jacoco.exec
surefire*.tmp
*.dump
*.dumpstream

# JVM crash logs
hs_err_pid*
replay_pid*

# Service-local env files (if added later)
.env
.env.*
!.env.example
